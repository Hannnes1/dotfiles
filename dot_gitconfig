[user]
	email = hannes.hultergard@gmail.com
	name = Hannes Hultergård
	signingkey = ~/.ssh/id_ed25519.pub
[pull]
	rebase = true
[init]
	defaultBranch = master
[commit]
	gpgsign = true
[push]
	autoSetupRemote = true
	followTags = true
[safe]
	directory = /opt/lampp/htdocs/burmond/wp-content/themes/burmond
[core]
	excludesfile = ~/.gitignore
	editor = nvim
[merge]
	ff = no
	commit = no
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[alias]
	tree = log --graph --oneline --all --decorate
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = /home/hannes/.ssh/allowed_signers

[url "git@github.com:"]
    insteadOf = "https://github.com/"
[mergetool "unityyamlmerge"]
	trustExitCode = false
  cmd = '/home/hannes/Unity/Hub/Editor/6000.3.5f1/Editor/Data/Tools/UnityYAMLMerge' merge -p "$BASE" "$REMOTE" "$LOCAL" "$MERGED"
